<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.abc.chat4j.platform.mapper.ConversationMapper">

    <resultMap type="Conversation" id="ConversationResult">
        <result property="conversationId"    column="conversation_id"    />
        <result property="userId"    column="user_id"    />
        <result property="roomId"    column="room_id"    />
        <result property="activeTime"    column="active_time"    />
        <result property="lastMsgId"    column="last_msg_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="status"    column="status"    />
        <result property="ver"    column="ver"    />
    </resultMap>

    <sql id="selectConversationVo">
        select conversation_id, user_id, room_id, active_time, last_msg_id, create_time, update_time, status, ver from tb_conversation
    </sql>

    <select id="selectConversationList" resultMap="ConversationResult">
        select conversation_id, user_id, room_id, active_time, last_msg_id, status from tb_conversation
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="minUpdateTime != null">and update_time >= #{minUpdateTime}</if>
        </where>
    </select>

</mapper>
