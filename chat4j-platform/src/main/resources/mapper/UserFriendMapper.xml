<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.abc.chat4j.platform.mapper.UserFriendMapper">

    <resultMap type="UserFriend" id="UserFriendResult">
        <result property="userFriendId"    column="user_friend_id"    />
        <result property="userId"    column="user_id"    />
        <result property="friendId"    column="friend_id"    />
        <result property="remark"    column="remark"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="status"    column="status"    />
        <result property="ver"    column="ver"    />
    </resultMap>

    <sql id="selectUserFriendVo">
        select user_friend_id, user_id, friend_id, remark, create_time, update_time, status, ver from tb_user_friend
    </sql>
    <select id="selectByUidAndFriendId" resultMap="UserFriendResult">
        select * from tb_user_friend
        where user_id = #{userId} and friend_id = #{friendId}
    </select>
    <select id="selectUserFriendList" resultMap="UserFriendResult">
        select * from tb_user_friend
        <where>
            <if test="userId != null">and user_id = #{userId}</if>
            <if test="minUpdateTime != null">and update_time >= #{minUpdateTime}</if>
        </where>
    </select>

</mapper>
